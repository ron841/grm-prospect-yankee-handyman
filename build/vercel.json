{
  "version": 2,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [{"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}]
    },
    {
      "source": "/(favicon|favicon-32|og-image|logo).:ext(png|jpg|ico)",
      "headers": [{"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}]
    }
  ]
}

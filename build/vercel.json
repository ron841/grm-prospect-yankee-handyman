{
  "version": 2,
  "headers": [
    {
      "source": "/(.*\\.(jpg|png|webp|woff2|ico))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    }
  ],
  "cleanUrls": true
}